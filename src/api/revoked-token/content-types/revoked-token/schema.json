{
  "kind": "collectionType",
  "collectionName": "revoked_tokens",
  "info": {
    "singularName": "revoked-token",
    "pluralName": "revoked-tokens",
    "displayName": "Revoked Token",
    "description": "JWT hashes that have been explicitly logged out"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "tokenHash": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "revokedAt": {
      "type": "datetime",
      "required": true
    },
    "expiresAt": {
      "type": "datetime"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
