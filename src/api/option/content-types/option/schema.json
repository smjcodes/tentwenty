{
  "kind": "collectionType",
  "collectionName": "options",
  "info": {
    "singularName": "option",
    "pluralName": "options",
    "displayName": "Option",
    "description": "Selectable options for each question"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "question": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::question.question",
      "inversedBy": "options",
      "required": true
    },
    "text": {
      "type": "string",
      "required": true
    },
    "isCorrect": {
      "type": "boolean",
      "default": false,
      "required": true,
      "private": true
    }
  }
}
