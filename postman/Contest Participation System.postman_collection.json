            }
          }
        },
        {
          "name": "My Prizes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/me/prizes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "me", "prizes"]
            }
          }
        },
        {
          "name": "My Prizes - VIP User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vipJwt}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/me/prizes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "me", "prizes"]
            }
          }
        }
      ]
    }
  ]
}
