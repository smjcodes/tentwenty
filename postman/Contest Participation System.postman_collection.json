                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/me?populate=role",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"],
